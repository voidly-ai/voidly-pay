{
  "name": "@voidly/pay-mcp",
  "version": "0.1.3",
  "description": "MCP server exposing Voidly Pay tools (transfer, escrow, x402, streams, subscriptions, webhooks, observability) to Claude Code, Cursor, Windsurf, and any MCP-compatible client.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "voidly-pay-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@voidly/pay": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "voidly",
    "voidly-pay",
    "voidly-pay-mcp",
    "claude-code",
    "cursor",
    "windsurf",
    "claude-desktop",
    "agent-payments",
    "agent-pay",
    "ai-payments",
    "x402",
    "http-402",
    "facilitator",
    "stablecoin",
    "usdc",
    "base",
    "agent-to-agent",
    "stdio-transport",
    "anthropic-mcp",
    "agentic-payments",
    "autonomous-agents"
  ],
  "license": "MIT",
  "homepage": "https://voidly.ai/pay",
  "repository": {
    "type": "git",
    "url": "https://github.com/voidly-ai/voidly-pay"
  },
  "bugs": {
    "url": "https://github.com/voidly-ai/voidly-pay/issues"
  },
  "mcpName": "io.github.voidly-ai/pay-mcp"
}
