{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voidly.ai/schemas/voidly-pay-hydra/values.schema.json",
  "title": "voidly-pay-hydra — Helm chart values",
  "description": "Validates values.yaml. `helm install --set foo=bar` is checked against this before rendering.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["IfNotPresent", "Always", "Never"] }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1, "maximum": 50 },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "hydra": {
      "type": "object",
      "required": ["api", "capability", "priceCredits", "port"],
      "additionalProperties": false,
      "properties": {
        "api": { "type": "string", "format": "uri" },
        "capability": { "type": "string", "minLength": 1 },
        "priceCredits": { "type": "number", "minimum": 0, "maximum": 1000 },
        "slaHours": { "type": "integer", "minimum": 1, "maximum": 168 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "externalUrl": { "type": "string" }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "startup": { "type": "object" },
        "liveness": { "type": "object" },
        "readiness": { "type": "object" }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string", "enum": ["ReadWriteOnce", "ReadOnlyMany", "ReadWriteMany", "ReadWriteOncePod"] }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": { "type": "array" }
            }
          }
        },
        "tls": { "type": "array" }
      }
    },
    "securityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "automountServiceAccountToken": { "type": "boolean" },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "egressHosts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "string" }] },
        "maxUnavailable": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "string" }] }
      }
    }
  }
}
